{
  "name": "switchpp",
  "private": true,
  "description": "Switch++ brings third-party models into Claude Code, Claude Desktop, Codex CLI, and Codex Desktop with config switching, local gateway routing, and call observability.",
  "license": "SEE LICENSE IN LICENSE",
  "version": "1.0.1",
  "type": "module",
  "homepage": "https://sssstwee.github.io/switch-plus-plus/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sssstwee/switch-plus-plus.git"
  },
  "keywords": [
    "switchpp",
    "switch-plus-plus",
    "switch++",
    "ccswitch-alternative",
    "agent-router",
    "model-router",
    "model-switcher",
    "llm-gateway",
    "claude-code",
    "claude-code-third-party",
    "claude-code-switcher",
    "codex-third-party",
    "codex",
    "codex-cli",
    "codex-desktop",
    "claude-desktop",
    "hermes",
    "hermes-agent",
    "opencode",
    "openclaw",
    "pi",
    "third-party",
    "third-party-models",
    "third-party-config",
    "config-switcher",
    "config-manager",
    "ai-coding-agent",
    "ai-agent",
    "pi-coding-agent",
    "oh-my-pi",
    "oh-my-openagent",
    "oh-my-opencode",
    "local-gateway",
    "openai",
    "openai-api",
    "openai-compatible",
    "anthropic",
    "anthropic-api",
    "anthropic-compatible"
  ],
  "scripts": {
    "dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev --runner ../scripts/tauri-dev-runner.sh",
    "dev:web": "vite",
    "build": "tsc && vite build",
    "lint": "tsc --noEmit && pnpm lint:rust && pnpm fmt:rust",
    "test": "node scripts/run-tests.mjs",
    "test:rust": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo test --manifest-path src-tauri/Cargo.toml",
    "lint:rust": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "fmt:rust": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "verify": "pnpm test && pnpm build && pnpm test:rust && pnpm lint && git diff --check",
    "preview": "vite preview",
    "tauri:dev": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri dev",
    "tauri": "PATH=\"$HOME/.cargo/bin:$PATH\" tauri"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
